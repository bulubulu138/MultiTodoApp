{
  "name": "multi-todo-app",
  "version": "1.0.0",
  "description": "Multi-functional Todo Tool - Powerful Task Management Application",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json && electron dist/main/main.js",
    "dev:renderer": "webpack serve --config webpack.renderer.config.js",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "webpack --config webpack.renderer.config.js",
    "pack": "npm run build && electron-builder --dir",
    "predist": "npm run build",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:mac:local": "CI=false electron-builder --mac --x64 --config.compression=store",
    "dist:local": "node build-local.js",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [
    "electron",
    "todo",
    "productivity",
    "task-management"
  ],
  "author": "MultiTodo Team",
  "license": "MIT",
  "homepage": "https://github.com/yourusername/multi-todo-app",
  "devDependencies": {
    "@types/dagre": "^0.7.53",
    "@types/node": "^20.0.0",
    "@types/pako": "^2.0.4",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "concurrently": "^8.0.0",
    "css-loader": "^6.8.0",
    "dmg-builder": "^24.13.3",
    "electron": "^27.3.11",
    "electron-builder": "^24.13.3",
    "eslint": "^8.0.0",
    "fast-check": "^4.5.3",
    "html-webpack-plugin": "^5.5.0",
    "style-loader": "^3.3.0",
    "ts-loader": "^9.4.0",
    "typescript": "^5.0.0",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.0",
    "webpack-dev-server": "^4.15.0"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/is-prop-valid": "^1.4.0",
    "@types/react-window": "^1.8.8",
    "antd": "^5.12.0",
    "buffer": "^6.0.3",
    "chokidar": "^3.5.3",
    "crypto-browserify": "^3.12.1",
    "dagre": "^0.8.5",
    "events": "^3.3.0",
    "framer-motion": "^12.23.24",
    "global": "^4.4.0",
    "gray-matter": "^4.0.3",
    "html-to-image": "^1.11.13",
    "minisearch": "^7.2.0",
    "os-browserify": "^0.3.0",
    "pako": "^2.1.0",
    "path-browserify": "^1.0.1",
    "process": "^0.11.10",
    "quill": "^2.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-quill-new": "^3.6.0",
    "react-virtualized-auto-sizer": "^1.0.26",
    "react-window": "^2.2.3",
    "reactflow": "^11.11.4",
    "segment": "^0.1.3",
    "stream-browserify": "^3.0.0",
    "util": "^0.12.5",
    "uuid": "9.0.1"
  },
  "build": {
    "appId": "com.multitodo.app",
    "productName": "MultiTodo",
    "copyright": "Copyright © 2025 ${author}",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "detectUpdateChannel": false,
    "electronDownload": {
      "cache": "./electron-cache"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json",
      "!node_modules/**/test/**/*",
      "!node_modules/**/*.md",
      "!node_modules/**/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!node_modules/**/{test,__tests__,tests,powered-test,example,examples}",
      "!node_modules/**/*.d.ts",
      "!node_modules/.bin"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "artifactName": "MultiTodo-${version}-${arch}-setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MultiTodo",
      "perMachine": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "deleteAppDataOnUninstall": false,
      "unicode": true,
      "include": "assets/installer.nsh"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.productivity",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "gatekeeperAssess": false
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "title": "MultiTodo ${version}",
      "icon": "assets/icon_512x512.png",
      "format": "ULFO"
    },
    "electronVersion": "27.0.0"
  }
}
